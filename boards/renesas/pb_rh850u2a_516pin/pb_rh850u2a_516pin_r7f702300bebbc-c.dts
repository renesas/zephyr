/dts-v1/;

#include <rh850/renesas/rh850u2a/r7f702300bebbc-c.dtsi>
#include <dt-bindings/gpio/gpio.h>

#include "pb_rh850u2a_516pin-pinctrl.dtsi"

/ {
	model = "Renesas RH850 U2A 516pin";
	compatible = "renesas,pb-rh850u2a-516pin", "renesas,u2a";

	chosen {
		zephyr,console = &uart0;
		zephyr,shell-uart = &uart0;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,system-timer = &ostm0;
		zephyr,crc = &crc0;
	};

	aliases {
		led0 = &led0;
		watchdog0 = &wdtba;
	};

	leds {
		compatible = "gpio-leds";

		led0: led0 {
			gpios = <&ioport11 0 GPIO_ACTIVE_HIGH>;
			label = "LED0";
		};
	};
};

&ostm0 {
	status = "okay";

	timer {
		status = "okay";
	};
};

&rlin30 {
	pinctrl-0 = <&rlin30_default>;
	pinctrl-names = "default";
	status = "okay";

	uart0: uart {
		current-speed = <115200>;
		status = "okay";
	};
};

&mspi0 {
	pinctrl-0 = <&mspi0_default>;
	pinctrl-names = "default";
	channel = <0>;
	status = "okay";
};

&mspi1 {
	pinctrl-0 = <&mspi1_default>;
	pinctrl-names = "default";
	channel = <0>;
	status = "okay";
};

&ioport11 {
	status = "okay";
};

&iic0 {
	pinctrl-0 = <&iic0_default>;
	pinctrl-names = "default";
	clock-frequency = <100000>;
	status = "okay";
};

&iic1 {
	pinctrl-0 = <&iic1_default>;
	pinctrl-names = "default";
	clock-frequency = <100000>;
	status = "okay";
};

&wdtba {
	status = "okay";
};

&crc0 {
	status = "okay";
};
