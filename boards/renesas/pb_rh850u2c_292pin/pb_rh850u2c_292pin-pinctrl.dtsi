#include <dt-bindings/pinctrl/renesas/pinctrl-rh850u2c.h>

&pinctrl {
	rlin30_default: rlin30_default {
		group1 {
			psels = <RH850_PSEL(PORT_04, 1, ALT_OUT1)>,
				<RH850_PSEL(PORT_04, 2, ALT_IN1)>;
		};
	};

	irq17_ioport: irq17_ioport {
		group1 {
			psels = <RH850_PSEL(PORT_02, 5, ALT_IN14)>;
		};
	};

	irq35_ioport: irq35_ioport {
		group1 {
			psels = <RH850_PSEL(PORT_02, 4, ALT_IN14)>;
		};
	};

	etnf0_default: etnf0_default {
		group1 {
			psels = <RH850_PSEL(PORT_20, 4, ALT_OUT3)>,
				<RH850_PSEL(PORT_20, 11, ALT_OUT3)>,
				<RH850_PSEL(PORT_22, 2, ALT_OUT2)>;
			drive-strength = "high";
		};
		group2 {
			psels = <RH850_PSEL(PORT_20, 3, ALT_OUT3)>,
				<RH850_PSEL(PORT_20, 13, ALT_OUT4)>,
				<RH850_PSEL(PORT_21, 0, ALT_OUT2)>;
			drive-strength = "high";
			renesas,direct-control;
		};
	};
};
