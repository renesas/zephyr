/dts-v1/;

#include <rh850/renesas/rh850u2c/r7f702600afabb-c.dtsi>
#include <dt-bindings/gpio/gpio.h>

#include "pb_rh850u2c_292pin-pinctrl.dtsi"

/ {
	model = "Renesas RH850 U2C 292pin";
	compatible = "renesas,pb-rh850u2c-292pin", "renesas,u2c";

	chosen {
		zephyr,console = &uart0;
		zephyr,shell-uart = &uart0;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,system-timer = &ostm0;
	};
};

&ostm0 {
	status = "okay";

	timer {
		status = "okay";
	};
};

&rlin30 {
	pinctrl-0 = <&rlin30_default>;
	pinctrl-names = "default";
	status = "okay";

	uart0: uart {
		current-speed = <115200>;
		status = "okay";
	};
};
