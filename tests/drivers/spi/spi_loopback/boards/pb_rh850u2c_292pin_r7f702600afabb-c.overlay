&mspi0 {
	interrupts = <76 11>, <79 10>, <90 12>, <91 15>;
	spi-cs-sck-delay = <1>;
	spi-sck-sck-delay = <1>;

	slow@0 {
		compatible = "test-spi-loopback-slow";
		reg = <0>;
		spi-max-frequency = <500000>;
	};

	fast@0 {
		compatible = "test-spi-loopback-fast";
		reg = <0>;
		spi-max-frequency = <1000000>;
	};
};
