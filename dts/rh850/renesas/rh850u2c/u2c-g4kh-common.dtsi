				reg = <0x1a>;
				interrupt-controller;
				interrupts = <231 1>;
				#interrupt-cells = <2>;
				#irq-cells = <1>;
				status = "disabled";
			};

			irq27: irq27@1b {
				#address-cells = <1>;
