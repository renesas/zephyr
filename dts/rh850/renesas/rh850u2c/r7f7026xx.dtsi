#include <rh850/renesas/rh850u2c/u2c-g4kh-common.dtsi>
#include <zephyr/dt-bindings/clock/renesas_rh850u2c_clock.h>
#include <zephyr/dt-bindings/gpio/gpio.h>
#include <freq.h>

/ {
	clocks {
		mosc: main-osc {
			compatible = "fixed-clock";
			clock-frequency = <DT_FREQ_M(20)>;
			#clock-cells = <0>;
			status = "okay";
		};

		hsiosc: hs-int-osc {
			compatible = "fixed-clock";
			clock-frequency = <DT_FREQ_M(200)>;
			#clock-cells = <0>;
			status = "okay";
		};

		lsiosc: ls-int-osc {
			compatible = "fixed-clock";
			clock-frequency = <DT_FREQ_K(240)>;
			#clock-cells = <0>;
			status = "okay";
		};

		iosc: int-osc {
			compatible = "fixed-clock";
			clock-frequency = <DT_FREQ_M(200)>;
			clocks = <&hsiosc>;
			#clock-cells = <0>;
			status = "okay";
		};

		sscg0: sscg0 {
			compatible = "fixed-clock";
			clock-frequency = <DT_FREQ_M(800)>;
			clocks = <&mosc>;
			#clock-cells = <0>;
			status = "okay";
		};

		pll: pll {
			compatible = "fixed-clock";
			clock-frequency = <DT_FREQ_M(800)>;
			clocks = <&mosc>;
			#clock-cells = <0>;
			status = "okay";
		};
	};

	soc {
		sram0: memory@fe000000 {
			compatible = "mmio-sram";
			reg = <0xfe000000 DT_SIZE_K(384)>;
		};

		pwm0_master: pwm0_master@ffbf4000 {
			compatible = "renesas,rh850-taud-pwm";
			reg = <0xffbf4000 0x2000>;
			unit = <0>;
			channel = <0>;
			channel-type = "master";
			interrupts = <10 1>;
			interrupt-parent = <&intc2>;
			status = "disabled";
		};

		pwm0_slave: pwm0_slave@ffbf4004 {
			compatible = "renesas,rh850-taud-pwm";
			reg = <0xffbf4004 0x2000>;
			unit = <0>;
			channel = <1>;
			channel-type = "slave";
			master = <&pwm0_master>;
			interrupts = <149 1>;
			interrupt-parent = <&intc2>;
			#pwm-cells = <3>;
			status = "disabled";
		};

		pwm1_slave: pwm1_slave@ffbf4008 {
			compatible = "renesas,rh850-taud-pwm";
			reg = <0xffbf4008 0x2000>;
			unit = <0>;
			channel = <2>;
			channel-type = "slave";
			master = <&pwm0_master>;
			interrupts = <11 1>;
			interrupt-parent = <&intc2>;
			#pwm-cells = <3>;
			status = "disabled";
		};

		cgc: clock-controller {
			compatible = "renesas,rh850-cgc";
			#clock-cells = <1>;
			status = "okay";

			clk_sys_sscg0: clk-sys-sscg0 {
				compatible = "renesas,rh850-cgc-sysclk";
				clk-source = <0>;
				#clock-cells = <0>;
				status = "okay";
			};

			clk_sys_clean: clk-sys-clean {
				compatible = "renesas,rh850-cgc-sysclk";
				clk-source = <0>;
				#clock-cells = <0>;
				status = "okay";
			};

			clk_rlin3: clk-rlin3 {
				compatible = "renesas,rh850-cgc-pclk";
				clk-source = <1>;
				#clock-cells = <0>;
				status = "okay";
			};

			clk_rlin3_ch23: clk-rlin3-ch23 {
				compatible = "renesas,rh850-cgc-pclk";
				clk-source = <1>;
				#clock-cells = <0>;
				status = "okay";
			};

			clk_canfd_c: clk-canfd-c {
				compatible = "renesas,rh850-cgc-pclk";
				clk-source = <1>;
				#clock-cells = <0>;
				status = "okay";
			};

			clk_canfd_xin: clk-canfd-xin {
				compatible = "renesas,rh850-cgc-pclk";
				clk-source = <1>;
				#clock-cells = <0>;
				status = "okay";
			};

			clkc_canxl_ch0: clkc-canxl-ch0 {
				compatible = "renesas,rh850-cgc-pclk";
				clk-source = <1>;
				#clock-cells = <0>;
				status = "okay";
			};

			clkc_canxl_ch1: clkc-canxl-ch1 {
				compatible = "renesas,rh850-cgc-pclk";
				clk-source = <1>;
				#clock-cells = <0>;
				status = "okay";
			};

			clk_mspi: clk-mspi {
				compatible = "renesas,rh850-cgc-pclk";
				clk-source = <2>;
				#clock-cells = <0>;
				status = "okay";
			};

			clk_swdt: clk-swdt {
				compatible = "renesas,rh850-cgc-pclk";
				clk-source = <0>;
				#clock-cells = <0>;
				status = "okay";
			};

			clka_wdtba: clka-wdtba {
				compatible = "renesas,rh850-cgc-pclk";
				clk-source = <1>;
				#clock-cells = <0>;
				status = "okay";
			};

			clka_tauj: clka-tauj {
				compatible = "renesas,rh850-cgc-pclk";
				clk-source = <1>;
				#clock-cells = <0>;
				status = "okay";
			};

			clka_rtca: clka-rtca {
				compatible = "renesas,rh850-cgc-pclk";
				clk-source = <1>;
				#clock-cells = <0>;
				status = "okay";
			};

			clka_adc: clka-adc {
				compatible = "renesas,rh850-cgc-pclk";
				clk-source = <1>;
				#clock-cells = <0>;
				status = "okay";
			};

			extclk0: extclk0 {
				compatible = "renesas,rh850-cgc-pclk";
				clk-source = <4>;
				div = <0>;
				#clock-cells = <0>;
				status = "okay";
			};

			extclk1: extclk1 {
				compatible = "renesas,rh850-cgc-pclk";
				clk-source = <4>;
				div = <0>;
				#clock-cells = <0>;
				status = "okay";
			};

			clka_wdtb: clka-wdtb {
				compatible = "renesas,rh850-cgc-pclk";
				clk-source = <1>;
				#clock-cells = <0>;
				status = "okay";
			};
		};

		ostm0: ostm0@ffbf0000 {
			compatible = "renesas,rh850-ostm";
			reg = <0xffbf0000 0x20>;
			channel = <0>;
			interrupts = <63 1>;
			interrupt-names = "overflow";
			interrupt-parent = <&intc2>;
			clocks = <&cgc RH850_PCLK(OSTM, 0, PCLK)>;
			status = "disabled";

			counter {
				compatible = "renesas,rh850-ostm-counter";
				status = "disabled";
			};

			timer {
				compatible = "renesas,rh850-ostm-timer";
				status = "disabled";
			};
		};

		ostm1: ostm1@ff89a100 {
			compatible = "renesas,rh850-ostm";
			reg = <0xff89a100 0x20>;
			channel = <1>;
			interrupts = <484 1>;
			interrupt-names = "overflow";
			interrupt-parent = <&intc2>;
			clocks = <&cgc RH850_PCLK(OSTM, 1, PCLK)>;
			status = "disabled";

			counter {
				compatible = "renesas,rh850-ostm-counter";
				status = "disabled";
			};

			timer {
				compatible = "renesas,rh850-ostm-timer";
				status = "disabled";
			};
		};

		rlin30: rlin30@ffc7c000 {
			compatible = "renesas,rh850-rlin3";
			interrupts = <173 1>, <174 1>, <175 1>, <176 1>;
			interrupt-names = "rlin3i", "txi", "rxi", "eri";
			reg = <0xffc7c000 0x35>;
			interrupt-parent = <&intc2>;
			clocks = <&cgc RH850_PCLK(RLIN3, 0, RLIN3)>;
			status = "disabled";

			uart0: uart {
				compatible = "renesas,rh850-rlin3-uart";
				channel = <0>;
				status = "disabled";
			};
		};

		rlin31: rlin31@ff89b100 {
			compatible = "renesas,rh850-rlin3";
			interrupts = <178 1>, <179 1>, <180 1>, <181 1>;
