		ioaport0: gpio@ffd90c80 {
			compatible = "renesas,rh850-gpio";
			reg = <0xffd90c80 0x40>;
			port = <0>;
			protected-write-mask = <20>;
			port-type = "aport";
			#gpio-cells = <2>;
			gpio-controller;
			status = "disabled";
		};

		ioaport1: gpio@ffd90cc0 {
			compatible = "renesas,rh850-gpio";
			reg = <0xffd90cc0 0x40>;
			port = <1>;
			protected-write-mask = <21>;
			port-type = "aport";
			#gpio-cells = <2>;
			gpio-controller;
			status = "disabled";
		};

