		iojport0: gpio@ffda0000 {
			compatible = "renesas,rh850-gpio";
			reg = <0xffda0000 0x40>;
			port = <0>;
			protected-write-mask = <255>;
			port-type = "jport";
			#gpio-cells = <2>;
			gpio-controller;
			status = "disabled";
		};

		dma0: dma@fff90000 {
			compatible = "renesas,rh850-dma";
			reg = <0xfff90000 0x5000>, <0xfff95000 0x020>;
			reg-names = "reg_main", "ext";
			interrupts = <41 1>, <42 1>, <43 1>, <44 1>,
				     <45 1>, <46 1>, <47 1>, <48 1>,
				     <49 1>, <50 1>, <51 1>, <52 1>,
				     <53 1>, <54 1>, <55 1>, <56 1>;
			interrupt-names = "ch0", "ch1", "ch2", "ch3",
					  "ch4", "ch5", "ch6", "ch7",
					  "ch8", "ch9", "ch10", "ch11",
					  "ch12", "ch13", "ch14", "ch15";
			interrupt-parent = <&intc2>;
			dma-unit = <0>;
			dma-channels = <16>;
			#dma-cells = <2>;
			status = "disabled";
		};

		dma1: dma@fff98000 {
			compatible = "renesas,rh850-dma";
			reg = <0xfff98000 0x5000>, <0xfff9d000 0x020>;
			reg-names = "reg_main", "ext";
			interrupts = <320 1>, <321 1>, <322 1>, <323 1>,
				     <324 1>, <325 1>, <326 1>, <327 1>,
				     <328 1>, <329 1>, <330 1>, <331 1>,
				     <332 1>, <333 1>, <334 1>, <335 1>;
			interrupt-names = "ch0", "ch1", "ch2", "ch3",
					  "ch4", "ch5", "ch6", "ch7",
					  "ch8", "ch9", "ch10", "ch11",
					  "ch12", "ch13", "ch14", "ch15";
			interrupt-parent = <&intc2>;
			dma-unit = <1>;
			dma-channels = <16>;
			#dma-cells = <2>;
			status = "disabled";
		};

		canfd_global: canfd-global@ff800000 {
			compatible = "renesas,rh850-canfd-global";
			reg = <0xff800000 DT_SIZE_K(128)>;
			interrupts = <104 1>, <105 1>;
			interrupt-names = "g_err", "g_recc";
			interrupt-parent = <&intc2>;
			status = "disabled";

			canfd0: canfd0 {
				compatible = "renesas,rh850-canfd";
				channel = <0>;
				interrupts = <107 1>, <106 1>, <108 1>;
				interrupt-names = "rxi", "eri", "txi";
				interrupt-parent = <&intc2>;
				clock-frequency = <80000000>;
				status = "disabled";
			};
		};
	};

	/* External CAN clock - to be overridden by boards that provide it */
	can_clk: can-clk {
		compatible = "fixed-clock";
		clock-frequency = <0>;
		#clock-cells = <0>;
	};
};
