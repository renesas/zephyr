		/* ETNF0 MAC node */
		etnf0: ethernet@ff1d0000 {
			compatible = "renesas,rh850-ethernet-etnf";
			reg = <0xff1d0000 0x77c>;
			interrupts = <536 0>;
			interrupt-parent = <&intc2>;
			phy-connection-type = "internal";
			mdio-interface = "shared";
			pma-filtered;
			status = "disabled";

			ct25205: phy {
				compatible = "renesas,ct25205-phy";
				phy-lsi-addr = <31>;
				plca-enable;
				plca-node-id = <0>;
				plca-node-count = <8>;
				plca-burst-count = <0>;
				plca-burst-timer = <128>;
				plca-to-timer = <32>;
				status = "okay";
			};
		};

		wdtba: watchdog@ff9a5000 {
			unit = <0>;
			compatible = "renesas,rh850-wdtb";
			interrupts = <306 0>;
			window-open-mode = "select-by-window-start";
			error-mode = "nmi-mode";
			clock-freq = <256>;
			reg = <0xff9a5000 0x14>;
			interrupt-parent = <&intc2>;
			status = "disabled";
		};

		wdtb0: watchdog@ffbf1000 {
			unit = <1>;
			compatible = "renesas,rh850-wdtb";
			interrupts = <22 0>;
			window-open-mode = "select-by-window-start";
			error-mode = "nmi-mode";
			clock-freq = <312500>;
			reg = <0xffbf1000 0x14>;
			interrupt-parent = <&intc2>;
			status = "disabled";
		};

		wdtb1: watchdog@ff899000 {
			unit = <2>;
			compatible = "renesas,rh850-wdtb";
			interrupts = <22 0>;
			window-open-mode = "select-by-window-start";
			error-mode = "nmi-mode";
			clock-freq = <312500>;
			reg = <0xff899000 0x14>;
			interrupt-parent = <&intc2>;
			status = "disabled";
		};

		ioport0: gpio@ffd90000 {
			compatible = "renesas,rh850-gpio";
			reg = <0xffd90000 0x40>;
			port = <0>;
			protected-write-mask = <0>;
			port-type = "port";
			#gpio-cells = <2>;
			gpio-controller;
			status = "disabled";
		};

		ioport2: gpio@ffd90080 {
			compatible = "renesas,rh850-gpio";
			reg = <0xffd90080 0x40>;
			port = <2>;
			protected-write-mask = <2>;
			port-type = "port";
			#gpio-cells = <2>;
			gpio-controller;
			status = "disabled";
		};

		ioport3: gpio@ffd900c0 {
			compatible = "renesas,rh850-gpio";
			reg = <0xffd900c0 0x40>;
