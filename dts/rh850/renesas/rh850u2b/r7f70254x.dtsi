		ioport34: gpio@ffd90880 {
			compatible = "renesas,rh850-gpio";
			reg = <0xffd90880 0x40>;
			port = <34>;
			protected-write-mask = <21>;
			port-type = "port";
			#gpio-cells = <2>;
			gpio-controller;
			status = "disabled";
		};

		ioportj0: gpio@ffda0000 {
			compatible = "renesas,rh850-gpio";
			reg = <0xffda0000 0x40>;
			port = <0>;
			protected-write-mask = <255>;
			port-type = "jport";
			#gpio-cells = <2>;
			gpio-controller;
			status = "disabled";
		};

		iic0: iic0@ff8e0000 {
			compatible = "renesas,rh850-iic";
			interrupts = <882 1>, <883 1>, <886 1>, <887 1>;
			interrupt-names = "rxi", "txi", "eri", "tei";
			reg = <0xff8e0000 0x2000>;
			interrupt-parent = <&intc2>;
			#address-cells = <1>;
			#size-cells = <0>;
			channel = <0>;
			status = "disabled";
		};

		iic1: iic1@ff8e2000 {
			compatible = "renesas,rh850-iic";
			interrupts = <884 1>, <885 1>, <888 1>, <889 1>;
			interrupt-names = "rxi", "txi", "eri", "tei";
			reg = <0xff8e2000 0x2000>;
			interrupt-parent = <&intc2>;
			#address-cells = <1>;
			#size-cells = <0>;
			channel = <1>;
			status = "disabled";
		};

		dma0: dma@fff90000 {
			compatible = "renesas,rh850-dma";
			reg = <0xfff90000 0x5000>, <0xfff95000 0x020>;
			reg-names = "reg_main", "ext";
			interrupts = <70 1>, <71 1>, <72 1>, <73 1>,
				     <74 1>, <75 1>, <76 1>, <77 1>,
				     <78 1>, <79 1>, <80 1>, <81 1>,
				     <82 1>, <83 1>, <84 1>, <85 1>;
			interrupt-names = "ch0", "ch1", "ch2", "ch3",
					  "ch4", "ch5", "ch6", "ch7",
					  "ch8", "ch9", "ch10", "ch11",
					  "ch12", "ch13", "ch14", "ch15";
			interrupt-parent = <&intc2>;
			dma-unit = <0>;
			dma-channels = <16>;
			#dma-cells = <2>;
			status = "disabled";
		};

		dma1: dma@fff98000 {
			compatible = "renesas,rh850-dma";
			reg = <0xfff98000 0x5000>, <0xfff9d000 0x020>;
			reg-names = "reg_main", "ext";
			interrupts = <825 1>, <826 1>, <827 1>, <828 1>,
				     <829 1>, <830 1>, <831 1>, <832 1>,
				     <833 1>, <834 1>, <835 1>, <836 1>,
				     <837 1>, <838 1>, <839 1>, <840 1>;
			interrupt-names = "ch0", "ch1", "ch2", "ch3",
					  "ch4", "ch5", "ch6", "ch7",
					  "ch8", "ch9", "ch10", "ch11",
					  "ch12", "ch13", "ch14", "ch15";
			interrupt-parent = <&intc2>;
			dma-unit = <1>;
			dma-channels = <16>;
			#dma-cells = <2>;
			status = "disabled";
		};
	};

	/* External CAN clock - to be overridden by boards that provide it */
	can_clk: can-clk {
		compatible = "fixed-clock";
		clock-frequency = <0>;
		#clock-cells = <0>;
	};
};
